<mvc:View
    controllerName="storepjt.ui5.controller.Embedded"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    height="100%">

    <Page
        showHeader="false"
        backgroundDesign="Solid"
        class="embeddedPage">
        <core:HTML
            id="iframeContainer"
            content="&lt;div id='iframeWrap' style='width:100%;height:100%;position:relative;'&gt;&lt;iframe id='ui5ContentFrame' src='about:blank' style='width:100%;height:100%;border:0;display:block;'&gt;&lt;/iframe&gt;&lt;/div&gt;"
            sanitizeContent="false"/>
    </Page>
</mvc:View>